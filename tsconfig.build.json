{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.build.tsbuildinfo",
    "target": "es2017",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["dom", "es2017", "scripthost"],
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "cjs",
    "jsx": "react-jsx"
  },
  "include": ["src"]
}
